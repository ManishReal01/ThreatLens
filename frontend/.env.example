# ThreatLens — Frontend Environment Variables
# Copy to frontend/.env.local and fill in your values.

# URL of the FastAPI backend (used server-side by Next.js rewrites)
# For Railway: set this to your Railway backend service URL (e.g. https://threatlens-api.up.railway.app)
# For local dev: leave as default
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
BACKEND_URL=http://127.0.0.1:8000
