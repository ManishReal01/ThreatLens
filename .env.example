# ThreatLens — Backend Environment Variables
# Copy to backend/.env and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────────
# MUST use Transaction Pooler URL (port 6543) — required for PgBouncer / Supabase
DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
TEST_DATABASE_URL=sqlite+aiosqlite:///./test.db

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Feed API Keys (leave blank to disable that feed) ─────────────────────────
OTX_API_KEY=
URLHAUS_API_KEY=
VT_API_KEY=

# ── Optional: Feed Schedule Overrides (minutes) ──────────────────────────────
# Supabase Nano has limited Disk IO — keep intervals long to spread writes.
# These are the recommended minimums; do NOT go lower.
URLHAUS_SCHEDULE_MINUTES=360
OTX_SCHEDULE_MINUTES=720
THREATFOX_SCHEDULE_MINUTES=360
VT_SCHEDULE_MINUTES=360
FEODOTRACKER_SCHEDULE_MINUTES=360
MALWAREBAZAAR_SCHEDULE_MINUTES=360
SSLBL_SCHEDULE_MINUTES=720
CISA_KEV_SCHEDULE_MINUTES=1440
MITRE_ATTACK_SCHEDULE_MINUTES=1440
GEOIP_ENRICHER_SCHEDULE_MINUTES=720
CORRELATION_SCHEDULE_MINUTES=360
